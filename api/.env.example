# Postgres connection.
#
# Recommended: paste the DATABASE_PUBLIC_URL from your Railway Postgres service
# (service → Variables tab). The plain DATABASE_URL on Railway is internal-only —
# only reachable from inside Railway, not from your laptop.
#
# Alternative for offline dev: `docker compose up -d` at repo root, then use:
#   postgresql://postgres:postgres@localhost:5433/uchicagofinance?schema=public
DATABASE_URL=""

# Fastify server
PORT=3000
NODE_ENV=development
